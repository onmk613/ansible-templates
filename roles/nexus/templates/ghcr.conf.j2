server {
  listen   *:80;
  server_name   {{ ghcr_servername }};
  location /v2 {
    proxy_set_header Host $host;
    proxy_pass http://nexus:8081/repository/ghcr-mirror/$request_uri;
  }
  location /v1 {
    proxy_set_header Host $host;
    proxy_pass http://nexus:8081/repository/ghcr-mirror/$request_uri;
  }
  location / {
    proxy_pass http://nexus:8081/repository/ghcr-mirror/;
  }
}
