<clickhouse>
    <listen_host replace="replace">0.0.0.0</listen_host>
    <http_port>{{ http_port }}</http_port>
    <tcp_port>{{ tcp_port }}</tcp_port>
    <interserver_http_port>{{ interserver_http_port }}</interserver_http_port>
    <interserver_http_host>{{ ansible_host }}</interserver_http_host>
    <logger>
        <level>debug</level>
        <size>512M</size>
        <count>10</count>
    </logger>
    <prometheus replace="replace">
        <endpoint>/metrics</endpoint>
        <port>{{ prometheus_port }}</port>
        <metrics>true</metrics>
        <events>true</events>
        <asynchronous_metrics>true</asynchronous_metrics>
        <errors>true</errors>
    </prometheus>
</clickhouse>
